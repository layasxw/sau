{
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "sau-rehab-app",
          "appId": "1:840406998562:android:10d58ccd7bc1888ed9b47b",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "sau-rehab-app",
          "configurations": {
            "android": "1:840406998562:android:10d58ccd7bc1888ed9b47b",
            "ios": "1:840406998562:ios:ebbf6ec714bc084ed9b47b",
            "macos": "1:840406998562:ios:ebbf6ec714bc084ed9b47b",
            "web": "1:840406998562:web:920888740df9c9b7d9b47b",
            "windows": "1:840406998562:web:aabea1580e17c158d9b47b"
          }
        }
      }
    }
  },
  "hosting": {
    "public": "build/web",
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "Permissions-Policy",
            "value": "microphone=*"
          }
        ]
      }
    ],
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "venv",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "runtime": "python313"
    }
  ]
}
